# Local Python/cache files
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Coverage artifacts
.coverage
.coverage.*
htmlcov/
coverage.xml

# Environments
.venv/
venv/
env/

# Nested reference clone of karpathy/autoresearch (its own git repo; ported, not vendored)
/autoresearch/

# Heavy/local research artifacts
runs/*
!runs/README.md
# Track the smoke run's README (diagnosis), but not its heavy artifacts (PNGs/jsonl).
!runs/smoke-001/
runs/smoke-001/*
!runs/smoke-001/README.md
# Track pilot-001's README + top-level summaries, but not per-condition heavy artifacts.
!runs/pilot-001/
runs/pilot-001/*
!runs/pilot-001/README.md
!runs/pilot-001/pilot_summary.md
!runs/pilot-001/aggregate.json
# autoresearch-jul3: track the write-up + immutable records + exact proposals (not PNGs/rollouts).
!runs/autoresearch-jul3/
runs/autoresearch-jul3/*
!runs/autoresearch-jul3/README.md
!runs/autoresearch-jul3/ledger.jsonl
!runs/autoresearch-jul3/results.tsv
!runs/autoresearch-jul3/candidate_*.json
!runs/autoresearch-jul3/multiseed/
runs/autoresearch-jul3/multiseed/*
!runs/autoresearch-jul3/multiseed/ledger.jsonl
!runs/autoresearch-jul3/multiseed/results.tsv
!runs/autoresearch-jul3/level3/
runs/autoresearch-jul3/level3/*
!runs/autoresearch-jul3/level3/ledger.jsonl
!runs/autoresearch-jul3/level3/results.tsv
# autoresearch-goal: the weekend hijack-hunt sweep (same track-light policy).
!runs/autoresearch-goal/
runs/autoresearch-goal/*
!runs/autoresearch-goal/README.md
!runs/autoresearch-goal/PROGRESS.md
!runs/autoresearch-goal/ANALYSIS.md
!runs/autoresearch-goal/BEST_CASE.md
!runs/autoresearch-goal/ledger.jsonl
!runs/autoresearch-goal/results.tsv
!runs/autoresearch-goal/candidate_*.json
!runs/autoresearch-goal/aggregate.json

!runs/autoresearch-hijack/
runs/autoresearch-hijack/*
!runs/autoresearch-hijack/HIJACK_SUCCESS.md
!runs/autoresearch-hijack/RESULT.md
!runs/autoresearch-hijack/PLAN.md
!runs/autoresearch-hijack/RESEARCH.md
!runs/autoresearch-hijack/REPRODUCE.md
!runs/autoresearch-hijack/logs/
runs/autoresearch-hijack/logs/*
!runs/autoresearch-hijack/logs/adaptive_cont.log
# tomato_sauce->milk retargeted sweep: track lightweight records only.
!runs/tomato-sauce-milk/
runs/tomato-sauce-milk/*
!runs/tomato-sauce-milk/README.md
!runs/tomato-sauce-milk/ledger.jsonl
!runs/tomato-sauce-milk/results.tsv
!runs/tomato-sauce-milk/candidate_*.json
# tomato_sauce->milk confirmation: track lightweight records only.
!runs/tomato-sauce-milk-confirm/
runs/tomato-sauce-milk-confirm/*
!runs/tomato-sauce-milk-confirm/README.md
!runs/tomato-sauce-milk-confirm/ledger.jsonl
!runs/tomato-sauce-milk-confirm/results.tsv
!runs/tomato-sauce-milk-confirm/candidate_*.json
# Exact tomato_sauce->ketchup audit: track the lightweight report only.
!runs/tomato-sauce-ketchup/
runs/tomato-sauce-ketchup/*
!runs/tomato-sauce-ketchup/README.md
data/external/*
!data/external/README.md
data/processed/*
!data/processed/README.md
